---
/**
 * Landing page — the REAL hero spike (Phase 5). Composed through BaseLayout so
 * it inherits the site chrome (head, grid backdrop, header, footer). This file
 * intentionally contains ONLY the hero: child 02 (landing-page) APPENDS the
 * remaining sections below the marked seam at the bottom of <main>.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import GridFrame from '../components/GridFrame.astro';
import Eyebrow from '../components/Eyebrow.astro';
import CursorHeading from '../components/CursorHeading.astro';
import PillButton from '../components/PillButton.astro';
import UIMock from '../components/UIMock.astro';
import LoopDiagram from '../components/LoopDiagram.astro';
import { withBase } from '../config/nav.ts';
import TheIdea from '../components/landing/TheIdea.astro';
import Concepts from '../components/landing/Concepts.astro';
import CommandShowcase from '../components/landing/CommandShowcase.astro';
import DiagramSection from '../components/landing/DiagramSection.astro';
import GetStarted from '../components/landing/GetStarted.astro';
import Faq from '../components/landing/Faq.astro';
import FinalCta from '../components/landing/FinalCta.astro';
---

<BaseLayout
  title="relay_ — outcome-driven agent orchestration"
  description="Relay turns a single outcome into a controlled loop of orchestrators and agents, surfacing every decision that needs you. Terminal-native by design."
  rails
>
  <Fragment slot="head">
    {
      /* Set the entrance-motion gate before first paint so above-the-fold
        `.reveal` blocks start hidden without a flash. Only engages when JS runs
        AND motion is allowed — otherwise the page stays fully static. */
    }
    <script is:inline>
      if (
        typeof window !== 'undefined' &&
        !window.matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        document.documentElement.classList.add('reveal-on');
      }
    </script>
  </Fragment>

  <div class="hero-frame">
    <GridFrame columns={2}>
      <section class="hero" aria-labelledby="hero-heading">
        <div class="hero__copy reveal">
          <Eyebrow marker>Outcome-driven orchestration</Eyebrow>
          <CursorHeading as="h1" display class="hero__heading" id="hero-heading">
            Define the outcome. Relay runs the loop.
          </CursorHeading>
          <p class="hero__lead">
            Relay turns a single goal into a controlled loop of orchestrators and agents — fanning
            out the work, converging on a critic gate, and surfacing every decision that needs you.
            Terminal-native by design.
          </p>
          <div class="hero__actions">
            <PillButton href={withBase('docs/what-is-relay')} variant="primary"
              >Read the docs</PillButton
            >
            <PillButton
              href="https://github.com/jasonhulbert/relay"
              variant="secondary"
              target="_blank"
              rel="noopener noreferrer"
            >
              View on GitHub
            </PillButton>
          </div>
        </div>

        <div class="hero__mock reveal">
          <UIMock variant="web" />
        </div>
      </section>

      <div class="hero__signal reveal" aria-labelledby="hero-signal-label">
        <Eyebrow class="hero__signal-label" id="hero-signal-label">The control loop</Eyebrow>
        <div class="hero__diagram"><LoopDiagram /></div>
      </div>
    </GridFrame>
  </div>

  {/* ── SEAM: landing sections (child 02) appended below the hero ── */}
  <TheIdea />
  <Concepts />
  <CommandShowcase />
  <DiagramSection />
  <GetStarted />
  <Faq />
  <FinalCta />
</BaseLayout>

<style>
  .hero-frame {
    max-width: 72rem;
    margin: 0 auto;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 60rem) {
    .hero {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: 3.5rem;
    }
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }
  .hero__heading {
    max-width: 16ch;
  }
  .hero__lead {
    margin: 0;
    max-width: 42ch;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--muted);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .hero__mock {
    width: 100%;
  }

  /* Signature visual — the loop diagram, framed below the hero copy. */
  .hero__signal {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }
  .hero__diagram {
    max-width: 44rem;
    margin: 1.25rem auto 0;
  }

  /* Gentle stagger so the hero reads as one settling motion, not three. */
  .hero__mock.is-revealed {
    transition-delay: 0.08s;
  }
  .hero__signal.is-revealed {
    transition-delay: 0.16s;
  }
</style>

<script>
  // Reveal `.reveal` blocks as they enter view. The hidden state only exists
  // when `html.reveal-on` is set (inline head script, JS + motion allowed), so
  // this is pure enhancement: if it never runs, everything is already visible.
  const targets = document.querySelectorAll<HTMLElement>('.reveal');
  if (
    document.documentElement.classList.contains('reveal-on') &&
    'IntersectionObserver' in window
  ) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
    );
    targets.forEach((el) => io.observe(el));
  } else {
    targets.forEach((el) => el.classList.add('is-revealed'));
  }
</script>
