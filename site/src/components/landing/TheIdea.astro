---
/**
 * TheIdea: the problem-first section. Names the pain operators feel today
 * (hand-authoring plans and babysitting agents) and frames Relay's inversion
 * (specify a verifiable outcome; Relay runs and verifies the loop). The two
 * contrast panels stand in for agno's "there is no runtime layer" device,
 * mapped onto Relay's domain.
 *
 * Phase-1 scope: structure + copy. The alternating section rhythm, decorative
 * seams, and motion are added in Phase 2.
 */
import Eyebrow from '../Eyebrow.astro';
import CursorHeading from '../CursorHeading.astro';
---

<section class="idea" aria-labelledby="idea-heading">
  <div class="idea__inner">
    <header class="idea__head">
      <Eyebrow marker>The shift</Eyebrow>
      <CursorHeading as="h2" id="idea-heading">You shouldn't have to babysit the agent.</CursorHeading>
      <p class="idea__lead">
        Most agent tools hand you a chat box and a sequence of steps to choreograph. You author the
        plan, watch every step, and step back in the moment it drifts. The plan is yours to write
        and yours to babysit.
      </p>
    </header>

    <div class="idea__contrast">
      <article class="idea__panel idea__panel--old">
        <p class="idea__panel-label">The old way</p>
        <p class="idea__panel-title">You write the steps. You run the loop.</p>
        <p class="idea__panel-body">
          Decompose the task by hand, prompt each step, and supervise the whole thing. When a model
          declares success it doesn't have, it's on you to catch it.
        </p>
      </article>

      <article class="idea__panel idea__panel--new">
        <p class="idea__panel-label">With Relay</p>
        <p class="idea__panel-title">You define the outcome. Relay runs the loop.</p>
        <p class="idea__panel-body">
          Specify a verifiable outcome — what "done" looks like and how to check it. Relay turns it
          into a loop it runs and verifies on its own, surfacing only the decisions that are
          genuinely yours.
        </p>
      </article>
    </div>
  </div>
</section>

<style>
  .idea__inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(3.5rem, 8vw, 6rem) clamp(1.5rem, 4vw, 3rem);
  }

  .idea__head {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 46rem;
  }
  .idea__lead {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .idea__contrast {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 48rem) {
    .idea__contrast {
      grid-template-columns: 1fr 1fr;
    }
  }

  .idea__panel {
    border: 1px solid var(--border);
    border-radius: 0.6rem;
    background: var(--surface);
    padding: 1.5rem;
  }
  .idea__panel--new {
    border-color: color-mix(in oklab, var(--accent) 45%, var(--border));
    background: var(--accent-soft);
  }

  .idea__panel-label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .idea__panel--new .idea__panel-label {
    color: var(--accent);
  }
  .idea__panel-title {
    margin: 0.75rem 0 0;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }
  .idea__panel-body {
    margin: 0.6rem 0 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
