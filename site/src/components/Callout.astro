---
/**
 * Callout: an aside for note/warn admonitions, primarily used inside MDX.
 * Body content is slotted so prose and inline markup render through.
 *
 * Props:
 *  - type: 'note' | 'warn' (default 'note')
 *  - title: heading text (defaults to a type-appropriate label)
 *  - class: extra classes on the root
 */
interface Props {
  type?: 'note' | 'warn';
  title?: string;
  class?: string;
}

const { type = 'note', title, class: className = '' } = Astro.props;
const defaultTitle = type === 'warn' ? 'Warning' : 'Note';
const icon = type === 'warn' ? '!' : 'i';
---

<aside class={`callout callout--${type} ${className}`.trim()}>
  <p class="callout__title">
    <span class="callout__icon" aria-hidden="true">{icon}</span>
    {title ?? defaultTitle}
  </p>
  <div class="callout__body"><slot /></div>
</aside>

<style>
  .callout {
    --callout-accent: var(--accent);
    border: 1px solid var(--border);
    border-left: 3px solid var(--callout-accent);
    border-radius: 0.5rem;
    background: var(--surface);
    padding: 0.85rem 1rem;
  }

  .callout--warn {
    /* Amber that reads on both themed surfaces without a dedicated token. */
    --callout-accent: #e0a33a;
  }

  .callout__title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
  }

  .callout__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-style: normal;
    color: #06120c;
    background: var(--callout-accent);
  }

  .callout__body {
    margin-top: 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .callout__body :global(:first-child) {
    margin-top: 0;
  }
  .callout__body :global(:last-child) {
    margin-bottom: 0;
  }
</style>
