---
/**
 * LoopDiagram: the signature inline SVG of Relay's control loop —
 * outcome (root) → orchestrators → leaf agents → critic gate, with the gate
 * looping back to the root. A "signal pulse" travels the edges via an animated
 * stroke dash in the accent color.
 *
 * Fully themeable: every fill/stroke reads a design token, so it flips with the
 * site theme. Under `prefers-reduced-motion: reduce` the pulse animation stops
 * and each edge holds a static accent segment — a frozen frame, never hidden.
 *
 * Props:
 *  - class: extra classes on the root <figure>
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

// Edges as straight/curved paths; pathLength is normalized to 100 so one dash
// pattern + one keyframe drives every edge regardless of true length. The
// negative delays stagger the pulses so the signal reads as continuous flow.
const edges = [
  'M360 79 L230 158', // root → orchestrator A
  'M360 79 L490 158', // root → orchestrator B
  'M230 202 L110 280', // orch A → agent 1
  'M230 202 L280 280', // orch A → agent 2
  'M490 202 L440 280', // orch B → agent 3
  'M490 202 L610 280', // orch B → agent 4
  'M110 320 L360 396', // agent 1 → critic
  'M280 320 L360 396', // agent 2 → critic
  'M440 320 L360 396', // agent 3 → critic
  'M610 320 L360 396', // agent 4 → critic
  'M445 420 C 695 392, 695 90, 435 56', // critic → root (loop back)
];

const leaves = [110, 280, 440, 610];
---

<figure class={`loop-diagram ${className}`.trim()}>
  <svg
    viewBox="0 0 720 480"
    role="img"
    aria-labelledby="loop-diagram-title loop-diagram-desc"
    preserveAspectRatio="xMidYMid meet"
  >
    <title id="loop-diagram-title">Relay control loop</title>
    <desc id="loop-diagram-desc">
      An outcome flows to orchestrators, which fan out to leaf agents; results converge on a critic
      gate that loops back to the outcome.
    </desc>

    <defs>
      <marker
        id="loop-arrow"
        viewBox="0 0 8 8"
        refX="6"
        refY="4"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M1 1 L6 4 L1 7" class="ld-arrow" fill="none"></path>
      </marker>
    </defs>

    {/* ── Edges: faint base path + traveling accent pulse ── */}
    <g class="ld-edges">
      {edges.map((d) => <path d={d} class="ld-edge" marker-end="url(#loop-arrow)" />)}
      {
        edges.map((d, i) => (
          <path
            d={d}
            class="ld-pulse"
            pathLength="100"
            style={`animation-delay:${(-i * 0.42).toFixed(2)}s`}
          />
        ))
      }
    </g>

    {/* ── Nodes ── */}
    <g class="ld-nodes">
      {/* root / outcome */}
      <g class="ld-node ld-node--root">
        <rect x="285" y="33" width="150" height="46" rx="8"></rect>
        <text x="360" y="54" class="ld-label">outcome</text>
        <text x="360" y="69" class="ld-sublabel">root goal</text>
      </g>

      {/* orchestrators */}
      <g class="ld-node">
        <rect x="155" y="158" width="150" height="44" rx="8"></rect>
        <text x="230" y="178" class="ld-label">orchestrator</text>
        <text x="230" y="193" class="ld-sublabel">plans the loop</text>
      </g>
      <g class="ld-node">
        <rect x="415" y="158" width="150" height="44" rx="8"></rect>
        <text x="490" y="178" class="ld-label">orchestrator</text>
        <text x="490" y="193" class="ld-sublabel">plans the loop</text>
      </g>

      {/* leaf agents */}
      {
        leaves.map((cx, i) => (
          <g class="ld-node ld-node--leaf">
            <rect x={cx - 60} y="280" width="120" height="40" rx="8" />
            <text x={cx} y="304" class="ld-label">
              agent {i + 1}
            </text>
          </g>
        ))
      }

      {/* critic gate */}
      <g class="ld-node ld-node--critic">
        <rect x="275" y="396" width="170" height="48" rx="8"></rect>
        <text x="360" y="417" class="ld-label">critic gate</text>
        <text x="360" y="433" class="ld-sublabel">approve · reject</text>
      </g>
    </g>

    <text x="664" y="242" class="ld-loop-label">loop</text>
  </svg>
</figure>

<style>
  .loop-diagram {
    margin: 0;
    width: 100%;
  }
  .loop-diagram svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Edges */
  .ld-edge {
    fill: none;
    stroke: var(--border);
    stroke-width: 1.5;
  }
  .ld-arrow {
    stroke: var(--muted);
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Traveling signal: a short accent segment running along each edge. */
  .ld-pulse {
    fill: none;
    stroke: var(--accent);
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 14 86;
    stroke-dashoffset: 0;
    filter: drop-shadow(0 0 3px var(--accent-soft));
    animation: ld-signal-flow 2.6s linear infinite;
  }
  @keyframes ld-signal-flow {
    from {
      stroke-dashoffset: 100;
    }
    to {
      stroke-dashoffset: 0;
    }
  }

  /* Nodes */
  .ld-node rect {
    fill: var(--surface);
    stroke: var(--border);
    stroke-width: 1.5;
  }
  .ld-node--root rect,
  .ld-node--critic rect {
    stroke: var(--accent);
  }
  .ld-label {
    fill: var(--text);
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    text-anchor: middle;
  }
  .ld-node--leaf .ld-label {
    font-size: 13px;
  }
  .ld-sublabel {
    fill: var(--muted);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    text-anchor: middle;
  }
  .ld-loop-label {
    fill: var(--accent);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-anchor: middle;
  }

  /* Static frame: stop the flow, leave a single accent segment at each edge
     start so the diagram still reads as the signal loop. */
  @media (prefers-reduced-motion: reduce) {
    .ld-pulse {
      animation: none;
      stroke-dashoffset: 88;
    }
  }
</style>
