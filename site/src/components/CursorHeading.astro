---
/**
 * CursorHeading: a heading with a trailing accent-green underscore cursor,
 * echoing the wordmark's terminal prompt. The blink is gated by
 * prefers-reduced-motion (steady, never hidden, when reduced).
 *
 * Props:
 *  - as: heading level to render (default 'h2')
 *  - display: use the large display type scale (default false)
 *  - class: extra classes on the root
 */
interface Props {
  as?: 'h1' | 'h2' | 'h3' | 'h4';
  display?: boolean;
  class?: string;
}

const { as: Tag = 'h2', display = false, class: className = '' } = Astro.props;
---

<Tag class={`cursor-heading ${display ? 'cursor-heading--display' : ''} ${className}`.trim()}>
  <slot /><span class="cursor-heading__cursor" aria-hidden="true">_</span>
</Tag>

<style>
  .cursor-heading {
    margin: 0;
    color: var(--text);
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.1;
  }

  .cursor-heading--display {
    font-size: var(--text-display-sm);
    letter-spacing: -0.02em;
    line-height: 1.04;
  }

  .cursor-heading__cursor {
    color: var(--accent);
    font-weight: 700;
    margin-left: 0.08em;
    animation: cursor-heading-blink 1.1s steps(1) infinite;
  }

  @keyframes cursor-heading-blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-heading__cursor {
      animation: none;
      opacity: 1;
    }
  }
</style>
