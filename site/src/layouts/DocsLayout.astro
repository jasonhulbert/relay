---
/**
 * DocsLayout: the three-pane docs shell, rendered through BaseLayout so it
 * inherits the site chrome. Left: sidebar nav (slot, fed by child 03). Center:
 * the article content (default slot). Right: an auto-TOC built from the page's
 * `headings` with a scroll-spy that marks the section in view. Below the
 * article: a prev/next region driven by `prev`/`next` props.
 *
 * Responsive collapse: the TOC hides below `xl`, the sidebar below `lg`; the
 * content column takes the full width on small screens (the primary nav stays
 * reachable via the Header's MobileNav).
 *
 * Slots:
 *  - default: article content
 *  - sidebar: left nav (child 03 feeds the doc tree)
 *  - search: forwarded to the Header search seam
 *
 * Props:
 *  - title / description: passed to BaseLayout
 *  - headings: MDX/Markdown heading list ({ depth, slug, text }) for the TOC
 *  - prev / next: { href, title } for the pagination region
 */
import BaseLayout from './BaseLayout.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface PageRef {
  href: string;
  title: string;
}
interface Props {
  title: string;
  description?: string;
  headings?: Heading[];
  prev?: PageRef;
  next?: PageRef;
}

const { title, description, headings = [], prev, next } = Astro.props;

// Auto-TOC: h2/h3 only — deeper levels add noise in a side rail.
const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={title} description={description}>
  <slot name="head" slot="head" />
  <slot name="search" slot="search" />

  <div class="docs">
    <aside class="docs__sidebar" aria-label="Docs navigation">
      <div class="docs__sidebar-inner">
        <slot name="sidebar" />
      </div>
    </aside>

    <div class="docs__main">
      <article class="docs__content">
        <slot />

        {
          (prev || next) && (
            <nav class="docs__pager" aria-label="Pagination">
              {prev ? (
                <a class="docs__pager-link docs__pager-link--prev" href={prev.href} rel="prev">
                  <span class="docs__pager-dir">← Previous</span>
                  <span class="docs__pager-title">{prev.title}</span>
                </a>
              ) : (
                <span />
              )}
              {next ? (
                <a class="docs__pager-link docs__pager-link--next" href={next.href} rel="next">
                  <span class="docs__pager-dir">Next →</span>
                  <span class="docs__pager-title">{next.title}</span>
                </a>
              ) : (
                <span />
              )}
            </nav>
          )
        }
      </article>
    </div>

    <aside class="docs__toc" aria-label="On this page">
      {
        tocItems.length > 0 && (
          <nav class="docs__toc-inner" data-toc>
            <p class="docs__toc-title">On this page</p>
            <ul class="docs__toc-list">
              {tocItems.map((h) => (
                <li class={`docs__toc-item docs__toc-item--d${h.depth}`}>
                  <a class="docs__toc-link" href={`#${h.slug}`} data-toc-link={h.slug}>
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </aside>
  </div>
</BaseLayout>

<style>
  .docs {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-gutter);
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem var(--spacing-gutter);
  }

  /* Sidebar appears at lg, TOC rail appears at xl. */
  @media (min-width: 64rem) {
    .docs {
      grid-template-columns: 15rem minmax(0, 1fr);
    }
  }
  @media (min-width: 80rem) {
    .docs {
      grid-template-columns: 15rem minmax(0, 1fr) 14rem;
    }
  }

  .docs__sidebar {
    display: none;
  }
  @media (min-width: 64rem) {
    .docs__sidebar {
      display: block;
    }
  }
  .docs__sidebar-inner {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
  }

  .docs__main {
    min-width: 0;
  }
  .docs__content {
    max-width: 46rem;
  }

  .docs__toc {
    display: none;
  }
  @media (min-width: 80rem) {
    .docs__toc {
      display: block;
    }
  }
  .docs__toc-inner {
    position: sticky;
    top: 5rem;
  }
  .docs__toc-title {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .docs__toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--border);
  }
  .docs__toc-item--d3 .docs__toc-link {
    padding-left: 1.5rem;
  }
  .docs__toc-link {
    display: block;
    margin-left: -1px;
    padding: 0.25rem 0 0.25rem 0.75rem;
    border-left: 1px solid transparent;
    font-size: 0.85rem;
    line-height: 1.3;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .docs__toc-link:hover {
    color: var(--text);
  }
  .docs__toc-link[aria-current='true'] {
    color: var(--accent-ink);
    border-left-color: var(--accent);
  }

  .docs__pager {
    display: flex;
    justify-content: space-between;
    gap: var(--spacing-gutter);
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .docs__pager-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.15s ease;
  }
  .docs__pager-link--next {
    text-align: right;
    align-items: flex-end;
  }
  .docs__pager-link:hover {
    border-color: var(--accent);
  }
  .docs__pager-dir {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .docs__pager-title {
    color: var(--text);
    font-weight: 500;
  }
</style>

<script is:inline>
  // Scroll-spy: mark the TOC link whose section is currently in view.
  (function () {
    var toc = document.querySelector('[data-toc]');
    if (!toc) return;
    var links = {};
    toc.querySelectorAll('[data-toc-link]').forEach(function (a) {
      links[a.getAttribute('data-toc-link')] = a;
    });
    var slugs = Object.keys(links);
    if (!slugs.length) return;

    var current = null;
    function setCurrent(slug) {
      if (slug === current) return;
      if (current && links[current]) links[current].removeAttribute('aria-current');
      current = slug;
      if (current && links[current]) links[current].setAttribute('aria-current', 'true');
    }

    var targets = slugs
      .map(function (s) {
        return document.getElementById(s);
      })
      .filter(Boolean);
    if (!targets.length) return;

    // Deterministic active-section pick: the last heading scrolled above the
    // offset band wins; at the page bottom, force the final heading (it may
    // never reach the top). rAF-throttled so scroll stays cheap.
    var OFFSET = 96; // sticky header + buffer
    var ticking = false;
    function update() {
      ticking = false;
      var slug = targets[0].id;
      for (var i = 0; i < targets.length; i++) {
        if (targets[i].getBoundingClientRect().top <= OFFSET) slug = targets[i].id;
        else break;
      }
      if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2) {
        slug = targets[targets.length - 1].id;
      }
      setCurrent(slug);
    }
    function onScroll() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(update);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();
</script>
