{
  "name": "relay",
  "version": "0.1.0",
  "description": "Relay: a terminal-based, multi-provider loop generator and orchestrator.",
  "license": "UNLICENSED",
  "private": true,
  "bin": {
    "relay": "dist/index.js"
  },
  "main": "dist/index.js",
