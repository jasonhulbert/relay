    "format:check": "prettier --check .",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "postject": "^1.0.0-alpha.6",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
